#Requires -Modules ActiveDirectory

$DaysBack   = 30
$OutputPath = "C:\Temp\NewADUsers_$(Get-Date -Format 'yyyyMMdd_HHmm').csv"
$Cutoff     = (Get-Date).AddDays(-$DaysBack)

New-Item -Path "C:\Temp" -ItemType Directory -Force | Out-Null

Write-Host "Querying AD for users created since $($Cutoff.ToString('yyyy-MM-dd'))..." -ForegroundColor Cyan

$Properties = @(
    "DisplayName", "GivenName", "Surname",
    "SamAccountName", "UserPrincipalName", "EmailAddress",
    "Title", "Department", "Company", "Office",
    "OfficePhone", "MobilePhone",
    "StreetAddress", "City", "State", "Country",
    "Manager", "DistinguishedName", "CanonicalName",
    "Enabled", "whenCreated", "LastLogonDate", "PasswordLastSet"
)

$Users = Get-ADUser -Filter { whenCreated -ge $Cutoff } -Properties $Properties

Write-Host "Found $($Users.Count) user(s). Exporting..." -ForegroundColor Green

$Users | Select-Object `
    DisplayName, GivenName, Surname,
    SamAccountName, UserPrincipalName, EmailAddress,
    Title, Department, Company, Office,
    OfficePhone, MobilePhone,
    StreetAddress, City, State, Country,
    Manager, DistinguishedName, CanonicalName,
    Enabled, whenCreated, LastLogonDate, PasswordLastSet |
Export-Csv -Path $OutputPath -NoTypeInformation -Encoding UTF8

Write-Host "Done: $OutputPath" -ForegroundColor Green
