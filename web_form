



<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>AD SE – New User</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;font-size:13px;color:#1a1a1a;background:#f5f5f5}
header{background:#185FA5;color:#fff;padding:14px 24px;display:flex;align-items:center;gap:12px}
header h1{font-size:16px;font-weight:600}
header p{font-size:11px;opacity:.8;margin-top:2px}
.wrap{max-width:920px;margin:20px auto;padding:0 16px 40px}
.card{background:#fff;border:1px solid #ddd;border-radius:8px;margin-bottom:16px;overflow:hidden}
.card-head{background:#f0f4f8;border-bottom:1px solid #ddd;padding:9px 16px;display:flex;align-items:center;gap:8px}
.card-head .dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.card-head h2{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:.06em;color:#333}
.card-body{padding:16px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:12px 20px}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px 20px}
.grid1{display:grid;grid-template-columns:1fr;gap:12px}
.f{display:flex;flex-direction:column;gap:3px}
.f label{font-size:11px;font-weight:600;color:#555}
.req-star{color:#c0392b}
.f input,.f select,.f textarea{padding:7px 10px;font-size:12px;border:1px solid #ccc;border-radius:5px;background:#fff;color:#1a1a1a;font-family:inherit;outline:none;width:100%}
.f input:focus,.f select:focus,.f textarea:focus{border-color:#185FA5;box-shadow:0 0 0 2px rgba(24,95,165,.15)}
.f input.invalid,.f select.invalid{border-color:#c0392b;background:#fff5f5}
.errmsg{font-size:10px;color:#c0392b;display:none;margin-top:1px}
.errmsg.show{display:block}
.f textarea{resize:vertical;min-height:60px}
.hint{font-size:10px;color:#888;margin-top:1px}
.inline-input{display:flex;align-items:center}
.inline-input input{border-radius:5px 0 0 5px;border-right:none;flex:1}
.inline-input .suffix,.inline-input .prefix{padding:7px 10px;background:#f0f4f8;border:1px solid #ccc;font-size:12px;color:#666;white-space:nowrap}
.inline-input .suffix{border-radius:0 5px 5px 0;border-left:none}
.inline-input .prefix{border-radius:5px 0 0 5px;border-right:none}
.inline-input .prefix+input{border-radius:0 5px 5px 0;border-left:none}
.checks{display:grid;grid-template-columns:1fr 1fr;gap:2px;margin-top:10px}
.chk{display:flex;align-items:center;gap:7px;padding:5px 0}
.chk input[type=checkbox]{width:14px;height:14px;accent-color:#185FA5;flex-shrink:0;cursor:pointer}
.chk label{font-size:12px;color:#333;cursor:pointer}
.chk.disabled label{color:#aaa}
.pw-wrap{position:relative}
.pw-wrap input{padding-right:40px}
.pw-toggle{position:absolute;right:8px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;font-size:11px;color:#888;padding:2px 4px}
.strength-bar{height:3px;border-radius:2px;margin-top:3px;width:0;transition:width .3s,background .3s}
.strength-lbl{font-size:10px;margin-top:2px}
.val-box{display:none;background:#fff5f5;border:1px solid #e8b4b4;border-radius:7px;padding:12px 16px;margin-bottom:14px}
.val-box.show{display:block}
.val-box p{font-size:12px;font-weight:600;color:#c0392b;margin-bottom:6px}
.val-box ul{padding-left:18px}
.val-box li{font-size:11px;color:#922;margin-bottom:3px}
.action-bar{background:#fff;border:1px solid #ddd;border-radius:8px;padding:14px 16px;display:flex;gap:10px;align-items:center;flex-wrap:wrap}
.btn{display:inline-flex;align-items:center;gap:6px;padding:8px 18px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;border:none;transition:opacity .15s}
.btn:hover{opacity:.85}
.btn:active{transform:scale(.98)}
.btn-ghost{background:#f0f0f0;color:#444;border:1px solid #ccc}
.btn-blue{background:#185FA5;color:#fff}
.btn-green{background:#0F6E56;color:#fff}
.btn-purple{background:#534AB7;color:#fff}
.toast{position:fixed;bottom:20px;right:20px;padding:10px 18px;border-radius:8px;font-size:13px;color:#fff;display:none;z-index:9999;font-weight:500}
.legend{display:flex;gap:10px;margin-left:auto;align-items:center}
.badge{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:600}
.badge-r{background:#fff0f0;color:#c0392b;border:1px solid #e8b4b4}
.badge-o{background:#e8f4fb;color:#185FA5;border:1px solid #b5d4f4}
</style>
</head>
<body>

<header>
  <div>
    <h1>New user — Active Directory SE</h1>
    <p>nrn.nrcan.gc.ca &nbsp;·&nbsp; Windows Server 2022 / AD Security Edition</p>
  </div>
  <div class="legend">
    <span class="badge badge-r">* Required</span>
    <span class="badge badge-o">Optional</span>
  </div>
</header>

<div class="wrap">

<!-- IDENTITY -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#185FA5"></div><h2>Identity</h2></div>
  <div class="card-body">
    <div class="grid3">
      <div class="f">
        <label>First name <span class="req-star">*</span></label>
        <input type="text" id="firstName" placeholder="e.g. Jane">
        <span class="errmsg" id="e_firstName">First name is required</span>
      </div>
      <div class="f">
        <label>Initials</label>
        <input type="text" id="initials" maxlength="5" placeholder="e.g. M">
      </div>
      <div class="f">
        <label>Last name <span class="req-star">*</span></label>
        <input type="text" id="lastName" placeholder="e.g. Smith">
        <span class="errmsg" id="e_lastName">Last name is required</span>
      </div>
      <div class="f">
        <label>Display name <span class="req-star">*</span></label>
        <input type="text" id="displayName" placeholder="Auto-filled">
        <span class="errmsg" id="e_displayName">Display name is required</span>
      </div>
      <div class="f">
        <label>Full name (CN)</label>
        <input type="text" id="fullName" placeholder="Common name">
      </div>
      <div class="f">
        <label>Description</label>
        <input type="text" id="description" placeholder="e.g. IT Analyst – Ottawa">
      </div>
    </div>
  </div>
</div>

<!-- ACCOUNT -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#0F6E56"></div><h2>Account</h2></div>
  <div class="card-body">
    <div class="grid2">
      <div class="f">
        <label>User logon name (UPN) <span class="req-star">*</span></label>
        <div class="inline-input">
          <input type="text" id="upnPrefix" placeholder="firstname.lastname">
          <span class="suffix">@nrn.nrcan.gc.ca</span>
        </div>
        <span class="errmsg" id="e_upnPrefix">UPN is required</span>
      </div>
      <div class="f">
        <label>sAMAccountName (pre-Win2000) <span class="req-star">*</span></label>
        <div class="inline-input">
          <span class="prefix">NRN\</span>
          <input type="text" id="samAccount" placeholder="jsmith" maxlength="20">
        </div>
        <div class="hint">Max 20 chars, no special characters</div>
        <span class="errmsg" id="e_samAccount">sAMAccountName is required</span>
      </div>
      <div class="f">
        <label>Password</label>
        <div class="pw-wrap">
          <input type="password" id="password" placeholder="Min 12 chars">
          <button class="pw-toggle" type="button" onclick="togglePw('password')">show</button>
        </div>
        <div class="strength-bar" id="sbar"></div>
        <div class="strength-lbl" id="slbl"></div>
      </div>
      <div class="f">
        <label>Confirm password</label>
        <div class="pw-wrap">
          <input type="password" id="confirmPw" placeholder="Re-enter password">
          <button class="pw-toggle" type="button" onclick="togglePw('confirmPw')">show</button>
        </div>
        <span class="errmsg" id="e_confirmPw">Passwords do not match</span>
      </div>
      <div class="f">
        <label>Account expires</label>
        <select id="acctExpires" onchange="document.getElementById('expiryWrap').style.display=this.value==='date'?'':'none'">
          <option value="never">Never</option>
          <option value="date">End of date</option>
        </select>
      </div>
      <div class="f" id="expiryWrap" style="display:none">
        <label>Expiry date</label>
        <input type="date" id="expiryDate">
      </div>
      <div class="f">
        <label>Logon hours</label>
        <select id="logonHours">
          <option>All hours (default)</option>
          <option>Business hours only (8am–6pm Mon–Fri)</option>
          <option>Custom (contact AD admin)</option>
        </select>
      </div>
      <div class="f">
        <label>Log on to (workstations)</label>
        <input type="text" id="logonWorkstations" placeholder="All computers (default)">
      </div>
    </div>
    <div class="checks">
      <div class="chk"><input type="checkbox" id="mustChangePw" checked><label for="mustChangePw">User must change password at next logon</label></div>
      <div class="chk"><input type="checkbox" id="cannotChangePw"><label for="cannotChangePw">User cannot change password</label></div>
      <div class="chk"><input type="checkbox" id="pwNeverExpires"><label for="pwNeverExpires">Password never expires</label></div>
      <div class="chk"><input type="checkbox" id="accountDisabled"><label for="accountDisabled">Account is disabled</label></div>
      <div class="chk"><input type="checkbox" id="smartCardRequired"><label for="smartCardRequired">Smart card required for interactive logon</label></div>
      <div class="chk disabled"><input type="checkbox" id="accountLocked" disabled><label for="accountLocked">Account is locked out (read-only)</label></div>
    </div>
    <div class="f" style="margin-top:10px">
      <label>userAccountControl (auto-calculated)</label>
      <input type="text" id="uac" readonly style="color:#888;background:#f8f8f8">
    </div>
  </div>
</div>

<!-- ORGANISATION -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#534AB7"></div><h2>Organisation</h2></div>
  <div class="card-body">
    <div class="grid3">
      <div class="f">
        <label>Job title <span class="req-star">*</span></label>
        <input type="text" id="jobTitle" placeholder="e.g. Senior IT Analyst">
        <span class="errmsg" id="e_jobTitle">Job title is required</span>
      </div>
      <div class="f">
        <label>Department <span class="req-star">*</span></label>
        <input type="text" id="department" placeholder="e.g. IT Security">
        <span class="errmsg" id="e_department">Department is required</span>
      </div>
      <div class="f">
        <label>Company <span class="req-star">*</span></label>
        <input type="text" id="company" value="Natural Resources Canada">
        <span class="errmsg" id="e_company">Company is required</span>
      </div>
      <div class="f">
        <label>Manager</label>
        <input type="text" id="manager" placeholder="CN=John Doe,OU=Ottawa,...">
      </div>
      <div class="f">
        <label>Employee ID</label>
        <input type="text" id="employeeId" placeholder="e.g. NRC-00123">
      </div>
      <div class="f">
        <label>Employee type</label>
        <select id="employeeType">
          <option value="">— select —</option>
          <option>Full-time</option><option>Part-time</option><option>Contractor</option>
          <option>Consultant</option><option>Student / Co-op</option><option>Service account</option>
        </select>
      </div>
      <div class="f">
        <label>Division</label>
        <input type="text" id="division" placeholder="e.g. Earth Sciences Sector">
      </div>
    </div>
  </div>
</div>

<!-- PROFILE & OU -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#D85A30"></div><h2>Profile &amp; OU placement</h2></div>
  <div class="card-body">
    <div class="grid2">
      <div class="f">
        <label>Organizational Unit (OU) <span class="req-star">*</span></label>
        <select id="ouPath">
          <option value="">— select OU —</option>
          <optgroup label="Atlantic">
            <option value="OU=AMH-Users,OU=Amherst,OU=Atlantic,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Atlantic › Amherst › Users</option>
            <option value="OU=COR-Users,OU=Comer_Brook,OU=Atlantic,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Atlantic › Comer Brook › Users</option>
            <option value="OU=DAR-Users,OU=Dartmouth,OU=Atlantic,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Atlantic › Dartmouth › Users</option>
          </optgroup>
          <optgroup label="Central">
            <option value="OU=CHK-Users,OU=Chalk_River,OU=Central,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Central › Chalk River › Users</option>
            <option value="OU=HAM-Users,OU=Hamilton,OU=Central,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Central › Hamilton › Users</option>
            <option value="OU=SSM-Users,OU=Sault_Ste_Marie,OU=Central,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Central › Sault Ste. Marie › Users</option>
            <option value="OU=OTT-Users,OU=Ottawa,OU=Central,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Central › Ottawa › Users</option>
          </optgroup>
          <optgroup label="Pacific">
            <option value="OU=SID-Users,OU=Sidney,OU=Pacific,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Pacific › Sidney › Users</option>
            <option value="OU=VAN-Users,OU=Vancouver,OU=Pacific,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Pacific › Vancouver › Users</option>
            <option value="OU=MPW-Users,OU=Major_Project_West,OU=Pacific,OU=Locations,DC=nrn,DC=nrcan,DC=gc,DC=ca">Pacific › Major Project West › Users</option>
          </optgroup>
          <optgroup label="Enterprise">
            <option value="OU=Enterprise-Groups,OU=Enterprise-Resources,DC=nrn,DC=nrcan,DC=gc,DC=ca">Enterprise Resources › Groups</option>
          </optgroup>
        </select>
        <span class="errmsg" id="e_ouPath">OU placement is required</span>
      </div>
      <div class="f">
        <label>Profile path (roaming)</label>
        <input type="text" id="profilePath" placeholder="\\server\profiles\%username%">
      </div>
      <div class="f">
        <label>Logon script</label>
        <input type="text" id="logonScript" placeholder="e.g. logon.bat">
      </div>
      <div class="f">
        <label>Home folder — local path</label>
        <input type="text" id="homeFolderLocal" placeholder="C:\Users\%username%">
      </div>
      <div class="f">
        <label>Home folder — connect drive</label>
        <select id="homeDrive">
          <option value="">— none —</option>
          <option>H:</option><option>I:</option><option>J:</option><option>K:</option><option>U:</option><option>Z:</option>
        </select>
      </div>
      <div class="f">
        <label>Home folder — UNC path</label>
        <input type="text" id="homeFolder" placeholder="\\server\home\%username%">
      </div>
    </div>
  </div>
</div>

<!-- CONTACT -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#BA7517"></div><h2>Contact information</h2></div>
  <div class="card-body">
    <div class="grid3">
      <div class="f">
        <label>Email address <span class="req-star">*</span></label>
        <input type="email" id="email" placeholder="jane.smith@nrcan-rncan.gc.ca">
        <span class="errmsg" id="e_email">Valid email is required</span>
      </div>
      <div class="f">
        <label>Office phone</label>
        <input type="tel" id="officePhone" placeholder="+1 (613) 555-0100">
      </div>
      <div class="f">
        <label>Mobile / cell</label>
        <input type="tel" id="mobile" placeholder="+1 (613) 555-0199">
      </div>
      <div class="f">
        <label>Fax</label>
        <input type="tel" id="fax" placeholder="+1 (613) 555-0101">
      </div>
      <div class="f">
        <label>IP phone</label>
        <input type="text" id="ipPhone" placeholder="e.g. 5000">
      </div>
      <div class="f">
        <label>Web page</label>
        <input type="url" id="webPage" placeholder="https://...">
      </div>
    </div>
    <div class="grid2" style="margin-top:12px">
      <div class="f"><label>Office / room</label><input type="text" id="office" placeholder="Room 412, 580 Booth St"></div>
      <div class="f"><label>Street address</label><input type="text" id="streetAddress" placeholder="580 Booth Street"></div>
      <div class="f"><label>City</label><input type="text" id="city" placeholder="Ottawa"></div>
      <div class="f"><label>Province / State</label><input type="text" id="stateProvince" placeholder="Ontario"></div>
      <div class="f"><label>Postal / ZIP code</label><input type="text" id="postalCode" placeholder="K1A 0E4"></div>
      <div class="f">
        <label>Country</label>
        <select id="country"><option value="CA">Canada</option><option value="US">United States</option><option value="GB">United Kingdom</option><option value="OTHER">Other</option></select>
      </div>
    </div>
  </div>
</div>

<!-- REMOTE DESKTOP -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#639922"></div><h2>Remote desktop services</h2></div>
  <div class="card-body">
    <div class="grid2">
      <div class="f"><label>TS profile path</label><input type="text" id="tsProfilePath" placeholder="\\server\tsprofiles\%username%"></div>
      <div class="f"><label>TS home folder</label><input type="text" id="tsHomeFolder" placeholder="\\server\tshome\%username%"></div>
    </div>
    <div class="checks" style="margin-top:10px">
      <div class="chk"><input type="checkbox" id="allowRDP" checked><label for="allowRDP">Allow remote desktop connection</label></div>
      <div class="chk"><input type="checkbox" id="tsEndSession"><label for="tsEndSession">End a disconnected session</label></div>
    </div>
  </div>
</div>

<!-- SECURITY -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#A32D2D"></div><h2>Security &amp; AD SE settings</h2></div>
  <div class="card-body">
    <div class="grid2">
      <div class="f">
        <label>Privileged access tier</label>
        <select id="tier">
          <option value="">— standard user —</option>
          <option value="T1">Tier 1 — Master owner / forest admin</option>
          <option value="T2">Tier 2 — Domain operator / access management</option>
          <option value="T3">Tier 3 — Location administrator</option>
        </select>
      </div>
      <div class="f">
        <label>Delegation model</label>
        <select id="delegation">
          <option value="none">None</option>
          <option value="constrained">Constrained delegation (Kerberos)</option>
          <option value="resource">Resource-based constrained delegation</option>
        </select>
      </div>
      <div class="f">
        <label>Kerberos encryption types</label>
        <select id="encryptionType">
          <option value="aes256">AES256 only (recommended — AD SE default)</option>
          <option value="aes128_256">AES128 + AES256</option>
          <option value="rc4_aes">RC4 + AES (legacy — not recommended)</option>
        </select>
      </div>
      <div class="f">
        <label>SPN (Service Principal Name)</label>
        <input type="text" id="spn" placeholder="HTTP/host.nrn.nrcan.gc.ca">
        <div class="hint">Leave blank for standard users</div>
      </div>
      <div class="f">
        <label>Protected Users group</label>
        <select id="protectedUsers">
          <option value="no">No — standard</option>
          <option value="yes">Yes — add to Protected Users</option>
        </select>
        <div class="hint">Disables NTLM, DES, RC4, unconstrained delegation</div>
      </div>
    </div>
    <div class="checks" style="margin-top:12px">
      <div class="chk"><input type="checkbox" id="sensitiveAccount"><label for="sensitiveAccount">Account is sensitive and cannot be delegated</label></div>
      <div class="chk"><input type="checkbox" id="desEncryption"><label for="desEncryption">Use DES encryption (not recommended)</label></div>
      <div class="chk"><input type="checkbox" id="noPreAuth"><label for="noPreAuth">Do not require Kerberos pre-authentication</label></div>
      <div class="chk"><input type="checkbox" id="trustedForDelegation"><label for="trustedForDelegation">Trusted for delegation (unconstrained)</label></div>
      <div class="chk"><input type="checkbox" id="mfaRequired" checked><label for="mfaRequired">MFA required for privileged access</label></div>
      <div class="chk"><input type="checkbox" id="pawRequired"><label for="pawRequired">Require Privileged Access Workstation (PAW)</label></div>
    </div>
  </div>
</div>

<!-- GROUPS -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#7F77DD"></div><h2>Group membership</h2></div>
  <div class="card-body">
    <div class="grid2">
      <div class="f">
        <label>Primary group</label>
        <input type="text" id="primaryGroup" value="Domain Users" readonly style="color:#888;background:#f8f8f8">
      </div>
      <div class="f">
        <label>Additional security groups (comma-separated)</label>
        <input type="text" id="memberOf" placeholder="SG-IT-Servers, RBAC-Location-Ottawa-Admins">
      </div>
    </div>
  </div>
</div>

<!-- ADDITIONAL -->
<div class="card">
  <div class="card-head"><div class="dot" style="background:#888"></div><h2>Additional attributes</h2></div>
  <div class="card-body">
    <div class="grid3">
      <div class="f">
        <label>Locale</label>
        <select id="locale"><option value="en-CA">English (Canada)</option><option value="fr-CA">French (Canada)</option><option value="en-US">English (US)</option></select>
      </div>
      <div class="f"><label>Preferred language</label><input type="text" id="preferredLanguage" placeholder="e.g. en or fr"></div>
      <div class="f">
        <label>Time zone</label>
        <select id="timezone">
          <option>Eastern Time (ET)</option><option>Central Time (CT)</option>
          <option>Mountain Time (MT)</option><option>Pacific Time (PT)</option>
          <option>Atlantic Time (AT)</option><option>Newfoundland Time (NT)</option>
        </select>
      </div>
      <div class="f"><label>altSecurityIdentities</label><input type="text" id="altSecId" placeholder="X509:certificate DN"></div>
      <div class="f"><label>extensionAttribute1</label><input type="text" id="extAttr1" placeholder="Custom attribute"></div>
      <div class="f"><label>extensionAttribute2</label><input type="text" id="extAttr2" placeholder="Custom attribute"></div>
      <div class="f"><label>extensionAttribute3</label><input type="text" id="extAttr3" placeholder="Custom attribute"></div>
    </div>
    <div class="f" style="margin-top:12px">
      <label>Notes / info</label>
      <textarea id="notes" placeholder="Additional notes about this account..."></textarea>
    </div>
  </div>
</div>

<!-- VALIDATION SUMMARY -->
<div class="val-box" id="valBox">
  <p>Please complete the following required fields:</p>
  <ul id="valList"></ul>
</div>

<!-- ACTIONS -->
<div class="action-bar">
  <button class="btn btn-ghost" onclick="doReset()">Clear form</button>
  <div style="flex:1"></div>
  <button class="btn btn-blue" onclick="doSave()">&#128190; Save HTML</button>
  <button class="btn btn-green" onclick="doPDF()">&#128196; Export PDF</button>
  <button class="btn btn-purple" onclick="doJSON()">&#128203; Export JSON</button>
</div>

</div><!-- wrap -->

<div class="toast" id="toast"></div>

<script>
(function(){

// ── helpers ──────────────────────────────────────────────────────────────────
function gv(id){
  var el = document.getElementById(id);
  if(!el) return '';
  return (el.value || '').trim();
}
function cb(id){
  var el = document.getElementById(id);
  return el ? el.checked : false;
}
function showToast(msg, color){
  var t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = color || '#222';
  t.style.display = 'block';
  setTimeout(function(){ t.style.display = 'none'; }, 3000);
}

// ── auto-fill UPN / SAM / display ────────────────────────────────────────────
var manualUpn = false, manualSam = false, manualDisplay = false;
function autoFill(){
  var f = gv('firstName');
  var l = gv('lastName');
  var fl = f.toLowerCase().replace(/\s/g,'');
  var ll = l.toLowerCase().replace(/\s/g,'');
  if(!manualDisplay){
    var dn = document.getElementById('displayName');
    dn.value = (f + (f&&l?' ':'')+l);
  }
  if(!manualUpn){
    var upn = document.getElementById('upnPrefix');
    upn.value = fl && ll ? fl+'.'+ll : fl||ll;
  }
  if(!manualSam){
    var sam = document.getElementById('samAccount');
    sam.value = (fl ? fl[0] : '') + ll.substring(0, 19);
  }
  calcUAC();
}
document.getElementById('firstName').addEventListener('input', autoFill);
document.getElementById('lastName').addEventListener('input', autoFill);
document.getElementById('displayName').addEventListener('input', function(){ manualDisplay = true; });
document.getElementById('upnPrefix').addEventListener('input', function(){ manualUpn = true; });
document.getElementById('samAccount').addEventListener('input', function(){ manualSam = true; });

// ── password strength ─────────────────────────────────────────────────────────
document.getElementById('password').addEventListener('input', function(){
  var pw = this.value;
  var s = 0;
  if(pw.length>=8) s++;
  if(pw.length>=12) s++;
  if(/[A-Z]/.test(pw)) s++;
  if(/[0-9]/.test(pw)) s++;
  if(/[^A-Za-z0-9]/.test(pw)) s++;
  var colors = ['#ccc','#e74c3c','#e67e22','#f1c40f','#27ae60','#0F6E56'];
  var labels = ['','Too short','Weak','Fair','Strong','Very strong'];
  var widths  = ['0%','20%','40%','60%','80%','100%'];
  document.getElementById('sbar').style.width = widths[s];
  document.getElementById('sbar').style.background = colors[s];
  document.getElementById('slbl').textContent = labels[s];
  document.getElementById('slbl').style.color = colors[s];
});

// ── UAC ───────────────────────────────────────────────────────────────────────
function calcUAC(){
  var u = 512;
  if(cb('accountDisabled'))    u += 2;
  if(cb('pwNeverExpires'))     u += 65536;
  if(cb('smartCardRequired'))  u += 262144;
  if(cb('noPreAuth'))          u += 4194304;
  if(cb('trustedForDelegation')) u += 524288;
  if(cb('sensitiveAccount'))   u += 1048576;
  document.getElementById('uac').value = u + ' (0x' + u.toString(16).toUpperCase() + ')';
}
document.querySelectorAll('input[type=checkbox]').forEach(function(el){
  el.addEventListener('change', calcUAC);
});

// ── show/hide password ────────────────────────────────────────────────────────
window.togglePw = function(id){
  var el = document.getElementById(id);
  el.type = el.type === 'password' ? 'text' : 'password';
};

// ── required fields ───────────────────────────────────────────────────────────
var REQUIRED = [
  { id:'firstName',   label:'First name' },
  { id:'lastName',    label:'Last name' },
  { id:'displayName', label:'Display name' },
  { id:'upnPrefix',   label:'User logon name (UPN)' },
  { id:'samAccount',  label:'sAMAccountName' },
  { id:'jobTitle',    label:'Job title' },
  { id:'department',  label:'Department' },
  { id:'company',     label:'Company' },
  { id:'ouPath',      label:'Organizational Unit (OU)' },
  { id:'email',       label:'Email address' },
];

// live-clear errors
REQUIRED.forEach(function(r){
  var el = document.getElementById(r.id);
  if(!el) return;
  function tryClear(){
    if((el.value||'').trim()){
      el.classList.remove('invalid');
      var em = document.getElementById('e_'+r.id);
      if(em) em.classList.remove('show');
    }
  }
  el.addEventListener('input',  tryClear);
  el.addEventListener('change', tryClear);
});

function validate(){
  var errors = [];
  REQUIRED.forEach(function(r){
    var el = document.getElementById(r.id);
    var em = document.getElementById('e_'+r.id);
    if(!el) return;
    if(!(el.value||'').trim()){
      el.classList.add('invalid');
      if(em) em.classList.add('show');
      errors.push(r.label);
    } else {
      el.classList.remove('invalid');
      if(em) em.classList.remove('show');
    }
  });
  // password match
  var pw = gv('password'), cpw = gv('confirmPw');
  var cpe = document.getElementById('e_confirmPw');
  if(pw && cpw && pw !== cpw){
    document.getElementById('confirmPw').classList.add('invalid');
    if(cpe) cpe.classList.add('show');
    errors.push('Passwords do not match');
  } else {
    document.getElementById('confirmPw').classList.remove('invalid');
    if(cpe) cpe.classList.remove('show');
  }
  var box  = document.getElementById('valBox');
  var list = document.getElementById('valList');
  if(errors.length){
    list.innerHTML = errors.map(function(e){ return '<li>'+e+'</li>'; }).join('');
    box.classList.add('show');
    box.scrollIntoView({behavior:'smooth', block:'nearest'});
    return false;
  }
  box.classList.remove('show');
  return true;
}

// ── collect data ──────────────────────────────────────────────────────────────
function collect(){
  return {
    meta: {
      createdAt: new Date().toISOString(),
      domain: 'nrn.nrcan.gc.ca',
      adVersion: 'Windows Server 2022 / AD SE'
    },
    identity: {
      firstName:   gv('firstName'),
      initials:    gv('initials'),
      lastName:    gv('lastName'),
      displayName: gv('displayName'),
      fullName:    gv('fullName'),
      description: gv('description')
    },
    account: {
      upn:              gv('upnPrefix') + '@nrn.nrcan.gc.ca',
      samAccountName:   'NRN\\' + gv('samAccount'),
      passwordSet:      document.getElementById('password').value.length > 0,
      accountExpires:   gv('acctExpires') === 'never' ? 'Never' : gv('expiryDate'),
      logonHours:       gv('logonHours'),
      logonWorkstations: gv('logonWorkstations') || 'All computers',
      userAccountControl: document.getElementById('uac').value,
      flags: {
        mustChangePw:    cb('mustChangePw'),
        cannotChangePw:  cb('cannotChangePw'),
        pwNeverExpires:  cb('pwNeverExpires'),
        accountDisabled: cb('accountDisabled'),
        smartCardRequired: cb('smartCardRequired'),
        accountLocked:   false
      }
    },
    organisation: {
      jobTitle:     gv('jobTitle'),
      department:   gv('department'),
      company:      gv('company'),
      manager:      gv('manager'),
      employeeId:   gv('employeeId'),
      employeeType: gv('employeeType'),
      division:     gv('division')
    },
    profile: {
      ouPath:          gv('ouPath'),
      profilePath:     gv('profilePath'),
      logonScript:     gv('logonScript'),
      homeFolderLocal: gv('homeFolderLocal'),
      homeDrive:       gv('homeDrive'),
      homeFolder:      gv('homeFolder')
    },
    contact: {
      email:         gv('email'),
      officePhone:   gv('officePhone'),
      mobile:        gv('mobile'),
      fax:           gv('fax'),
      ipPhone:       gv('ipPhone'),
      webPage:       gv('webPage'),
      office:        gv('office'),
      streetAddress: gv('streetAddress'),
      city:          gv('city'),
      stateProvince: gv('stateProvince'),
      postalCode:    gv('postalCode'),
      country:       gv('country')
    },
    remoteDesktop: {
      tsProfilePath:        gv('tsProfilePath'),
      tsHomeFolder:         gv('tsHomeFolder'),
      allowRDP:             cb('allowRDP'),
      endDisconnectedSession: cb('tsEndSession')
    },
    security: {
      tier:           gv('tier') || 'Standard user',
      delegation:     gv('delegation'),
      encryptionType: gv('encryptionType'),
      spn:            gv('spn'),
      protectedUsers: gv('protectedUsers'),
      flags: {
        sensitiveAccount:    cb('sensitiveAccount'),
        desEncryption:       cb('desEncryption'),
        noPreAuth:           cb('noPreAuth'),
        trustedForDelegation: cb('trustedForDelegation'),
        mfaRequired:         cb('mfaRequired'),
        pawRequired:         cb('pawRequired')
      }
    },
    groups: {
      primaryGroup: gv('primaryGroup'),
      memberOf: gv('memberOf').split(',').map(function(s){ return s.trim(); }).filter(Boolean)
    },
    additional: {
      locale:               gv('locale'),
      preferredLanguage:    gv('preferredLanguage'),
      timezone:             gv('timezone'),
      altSecurityIdentities: gv('altSecId'),
      extensionAttribute1:  gv('extAttr1'),
      extensionAttribute2:  gv('extAttr2'),
      extensionAttribute3:  gv('extAttr3'),
      notes:                gv('notes')
    }
  };
}

// ── download helper ───────────────────────────────────────────────────────────
function download(content, filename, mime){
  var blob = (content instanceof Blob) ? content : new Blob([content], {type: mime});
  var url  = URL.createObjectURL(blob);
  var a    = document.createElement('a');
  a.href     = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  setTimeout(function(){
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }, 500);
}

function baseName(){
  var sam = gv('samAccount') || 'new';
  var dt  = new Date().toISOString().slice(0,10);
  return 'AD_User_' + sam + '_' + dt;
}

// ── EXPORT JSON ───────────────────────────────────────────────────────────────
window.doJSON = function(){
  validate(); // show warnings but don't block
  var d = collect();
  var str = JSON.stringify(d, null, 2);
  download(str, baseName() + '.json', 'application/json');
  showToast('JSON file saved to downloads', '#534AB7');
};

// ── SAVE HTML ─────────────────────────────────────────────────────────────────
window.doSave = function(){
  var d = collect();
  function rows(pairs){
    return pairs.map(function(p){
      var v = p[1];
      if(v === '' || v === null || v === undefined) return '';
      if(typeof v === 'boolean') v = v ? 'Yes' : 'No';
      return '<tr><td>'+p[0]+'</td><td>'+v+'</td></tr>';
    }).join('');
  }
  function sec(title, pairs){
    var r = rows(pairs);
    if(!r) return '';
    return '<h2>'+title+'</h2><table>'+r+'</table>';
  }
  var html = '<!DOCTYPE html><html><head><meta charset="utf-8"><title>AD User – '+d.identity.displayName+'</title>'
    +'<style>body{font-family:system-ui,sans-serif;max-width:820px;margin:2rem auto;padding:0 1rem;color:#1a1a1a}'
    +'h1{font-size:18px;color:#185FA5;margin-bottom:2px}p.sub{font-size:11px;color:#888;margin-bottom:1.5rem}'
    +'h2{font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:#185FA5;'
    +'margin:1.4rem 0 .4rem;border-bottom:2px solid #e0e0e0;padding-bottom:3px}'
    +'table{width:100%;border-collapse:collapse;font-size:12px;margin-bottom:.5rem}'
    +'td{padding:5px 8px;border-bottom:1px solid #f0f0f0;vertical-align:top}'
    +'td:first-child{color:#555;width:38%;font-weight:600}'
    +'td:last-child{color:#1a1a1a}'
    +'footer{margin-top:2rem;font-size:10px;color:#aaa;border-top:1px solid #eee;padding-top:8px}'
    +'</style></head><body>'
    +'<h1>Active Directory SE — User Record</h1>'
    +'<p class="sub">nrn.nrcan.gc.ca &nbsp;·&nbsp; Saved: '+new Date().toLocaleString()+'</p>';

  html += sec('Identity',[
    ['First name',d.identity.firstName],['Initials',d.identity.initials],
    ['Last name',d.identity.lastName],['Display name',d.identity.displayName],
    ['Full name (CN)',d.identity.fullName],['Description',d.identity.description]
  ]);
  html += sec('Account',[
    ['UPN',d.account.upn],['sAMAccountName',d.account.samAccountName],
    ['Password',d.account.passwordSet?'[set — not stored]':'[not set]'],
    ['Account expires',d.account.accountExpires],['Logon hours',d.account.logonHours],
    ['Logon workstations',d.account.logonWorkstations],
    ['userAccountControl',d.account.userAccountControl],
    ['Must change password',d.account.flags.mustChangePw],
    ['Cannot change password',d.account.flags.cannotChangePw],
    ['Password never expires',d.account.flags.pwNeverExpires],
    ['Account disabled',d.account.flags.accountDisabled],
    ['Smart card required',d.account.flags.smartCardRequired]
  ]);
  html += sec('Organisation',[
    ['Job title',d.organisation.jobTitle],['Department',d.organisation.department],
    ['Company',d.organisation.company],['Manager',d.organisation.manager],
    ['Employee ID',d.organisation.employeeId],['Employee type',d.organisation.employeeType],
    ['Division',d.organisation.division]
  ]);
  html += sec('Profile & OU',[
    ['OU path',d.profile.ouPath],['Profile path',d.profile.profilePath],
    ['Logon script',d.profile.logonScript],['Home folder (local)',d.profile.homeFolderLocal],
    ['Home drive',d.profile.homeDrive],['Home folder (UNC)',d.profile.homeFolder]
  ]);
  html += sec('Contact',[
    ['Email',d.contact.email],['Office phone',d.contact.officePhone],
    ['Mobile',d.contact.mobile],['Fax',d.contact.fax],
    ['IP phone',d.contact.ipPhone],['Web page',d.contact.webPage],
    ['Office / room',d.contact.office],['Street address',d.contact.streetAddress],
    ['City',d.contact.city],['Province / State',d.contact.stateProvince],
    ['Postal code',d.contact.postalCode],['Country',d.contact.country]
  ]);
  html += sec('Remote Desktop',[
    ['TS profile path',d.remoteDesktop.tsProfilePath],
    ['TS home folder',d.remoteDesktop.tsHomeFolder],
    ['Allow RDP',d.remoteDesktop.allowRDP],
    ['End disconnected session',d.remoteDesktop.endDisconnectedSession]
  ]);
  html += sec('Security & AD SE',[
    ['Tier',d.security.tier],['Delegation',d.security.delegation],
    ['Kerberos encryption',d.security.encryptionType],
    ['SPN',d.security.spn],['Protected Users',d.security.protectedUsers],
    ['Account sensitive',d.security.flags.sensitiveAccount],
    ['Use DES encryption',d.security.flags.desEncryption],
    ['No Kerberos pre-auth',d.security.flags.noPreAuth],
    ['Trusted for delegation',d.security.flags.trustedForDelegation],
    ['MFA required',d.security.flags.mfaRequired],
    ['PAW required',d.security.flags.pawRequired]
  ]);
  html += sec('Groups',[
    ['Primary group',d.groups.primaryGroup],
    ['Member of',d.groups.memberOf.join(', ')||'None']
  ]);
  html += sec('Additional',[
    ['Locale',d.additional.locale],['Preferred language',d.additional.preferredLanguage],
    ['Time zone',d.additional.timezone],
    ['altSecurityIdentities',d.additional.altSecurityIdentities],
    ['extensionAttribute1',d.additional.extensionAttribute1],
    ['extensionAttribute2',d.additional.extensionAttribute2],
    ['extensionAttribute3',d.additional.extensionAttribute3],
    ['Notes',d.additional.notes]
  ]);
  html += '<footer>NRCan Active Directory SE — Confidential &nbsp;·&nbsp; '+new Date().toLocaleString()+'</footer></body></html>';

  download(html, baseName()+'.html', 'text/html');
  showToast('HTML file saved to downloads', '#185FA5');
};

// ── EXPORT PDF ────────────────────────────────────────────────────────────────
window.doPDF = function(){
  validate(); // show warnings but don't block
  if(!window.jspdf || !window.jspdf.jsPDF){
    showToast('PDF library not ready — please wait a moment and try again', '#c0392b');
    return;
  }
  var d = collect();
  var doc = new window.jspdf.jsPDF({ orientation:'portrait', unit:'pt', format:'a4' });
  var PW = doc.internal.pageSize.getWidth();
  var PH = doc.internal.pageSize.getHeight();
  var ML = 40, CW = PW - ML*2;
  var y = 0;

  // header
  doc.setFillColor(24,95,165);
  doc.rect(0,0,PW,56,'F');
  doc.setTextColor(255,255,255);
  doc.setFontSize(16); doc.setFont('helvetica','bold');
  doc.text('Active Directory SE — New User Record', ML, 28);
  doc.setFontSize(9); doc.setFont('helvetica','normal');
  doc.text('nrn.nrcan.gc.ca  ·  Generated: ' + new Date().toLocaleString(), ML, 46);
  y = 72;

  function chkPage(need){
    if(y + need > PH - 36){ doc.addPage(); y = 36; }
  }
  function sectionHead(title, rgb){
    chkPage(22);
    doc.setFillColor(rgb[0],rgb[1],rgb[2]);
    doc.rect(ML, y, CW, 20, 'F');
    doc.setTextColor(255,255,255);
    doc.setFontSize(9); doc.setFont('helvetica','bold');
    doc.text(title, ML+6, y+14);
    y += 24;
  }
  function row(label, val){
    if(val === '' || val === null || val === undefined) return;
    var sval = String(val);
    chkPage(16);
    doc.setTextColor(80,80,80); doc.setFontSize(8.5); doc.setFont('helvetica','bold');
    doc.text(label, ML+4, y);
    doc.setTextColor(26,26,26); doc.setFont('helvetica','normal');
    var wrapped = doc.splitTextToSize(sval, CW - 136);
    doc.text(wrapped, ML+136, y);
    y += Math.max(14, wrapped.length * 12);
    doc.setDrawColor(220,220,220); doc.setLineWidth(0.3);
    doc.line(ML, y-1, ML+CW, y-1);
  }
  function brow(label, val){ row(label, val ? 'Yes' : 'No'); }

  sectionHead('Identity', [24,95,165]);
  row('First name', d.identity.firstName); row('Initials', d.identity.initials);
  row('Last name', d.identity.lastName); row('Display name', d.identity.displayName);
  row('Full name (CN)', d.identity.fullName); row('Description', d.identity.description);
  y += 4;

  sectionHead('Account', [15,110,86]);
  row('UPN', d.account.upn); row('sAMAccountName', d.account.samAccountName);
  row('Password', d.account.passwordSet ? '[set — not stored]' : '[not set]');
  row('Account expires', d.account.accountExpires);
  row('Logon hours', d.account.logonHours);
  row('Logon workstations', d.account.logonWorkstations);
  row('userAccountControl', d.account.userAccountControl);
  brow('Must change password at next logon', d.account.flags.mustChangePw);
  brow('Cannot change password', d.account.flags.cannotChangePw);
  brow('Password never expires', d.account.flags.pwNeverExpires);
  brow('Account disabled', d.account.flags.accountDisabled);
  brow('Smart card required', d.account.flags.smartCardRequired);
  y += 4;

  sectionHead('Organisation', [83,74,183]);
  row('Job title', d.organisation.jobTitle); row('Department', d.organisation.department);
  row('Company', d.organisation.company); row('Manager', d.organisation.manager);
  row('Employee ID', d.organisation.employeeId); row('Employee type', d.organisation.employeeType);
  row('Division', d.organisation.division);
  y += 4;

  sectionHead('Profile & OU placement', [153,60,29]);
  row('OU path', d.profile.ouPath); row('Profile path', d.profile.profilePath);
  row('Logon script', d.profile.logonScript); row('Home folder (local)', d.profile.homeFolderLocal);
  row('Home drive', d.profile.homeDrive); row('Home folder (UNC)', d.profile.homeFolder);
  y += 4;

  sectionHead('Contact information', [186,117,23]);
  row('Email', d.contact.email); row('Office phone', d.contact.officePhone);
  row('Mobile', d.contact.mobile); row('Fax', d.contact.fax);
  row('IP phone', d.contact.ipPhone); row('Web page', d.contact.webPage);
  row('Office / room', d.contact.office); row('Street address', d.contact.streetAddress);
  row('City', d.contact.city); row('Province / State', d.contact.stateProvince);
  row('Postal code', d.contact.postalCode); row('Country', d.contact.country);
  y += 4;

  sectionHead('Remote desktop services', [99,153,34]);
  row('TS profile path', d.remoteDesktop.tsProfilePath);
  row('TS home folder', d.remoteDesktop.tsHomeFolder);
  brow('Allow RDP', d.remoteDesktop.allowRDP);
  brow('End disconnected session', d.remoteDesktop.endDisconnectedSession);
  y += 4;

  sectionHead('Security & AD SE settings', [163,45,45]);
  row('Privileged access tier', d.security.tier);
  row('Delegation model', d.security.delegation);
  row('Kerberos encryption', d.security.encryptionType);
  row('SPN', d.security.spn);
  row('Protected Users', d.security.protectedUsers);
  brow('Account sensitive / cannot be delegated', d.security.flags.sensitiveAccount);
  brow('Use DES encryption', d.security.flags.desEncryption);
  brow('No Kerberos pre-auth', d.security.flags.noPreAuth);
  brow('Trusted for delegation (unconstrained)', d.security.flags.trustedForDelegation);
  brow('MFA required', d.security.flags.mfaRequired);
  brow('PAW required', d.security.flags.pawRequired);
  y += 4;

  sectionHead('Group membership', [127,119,221]);
  row('Primary group', d.groups.primaryGroup);
  row('Member of', d.groups.memberOf.join(', ') || 'None');
  y += 4;

  sectionHead('Additional attributes', [136,135,128]);
  row('Locale', d.additional.locale);
  row('Preferred language', d.additional.preferredLanguage);
  row('Time zone', d.additional.timezone);
  row('altSecurityIdentities', d.additional.altSecurityIdentities);
  row('extensionAttribute1', d.additional.extensionAttribute1);
  row('extensionAttribute2', d.additional.extensionAttribute2);
  row('extensionAttribute3', d.additional.extensionAttribute3);
  row('Notes', d.additional.notes);

  // page footers
  var pages = doc.internal.getNumberOfPages();
  for(var i = 1; i <= pages; i++){
    doc.setPage(i);
    doc.setFontSize(8); doc.setTextColor(180,180,180);
    doc.text('NRCan Active Directory SE — Confidential', ML, PH-16);
    doc.text('Page ' + i + ' of ' + pages, PW-ML, PH-16, {align:'right'});
  }

  var blob = doc.output('blob');
  download(blob, baseName()+'.pdf', 'application/pdf');
  showToast('PDF file saved to downloads', '#0F6E56');
};

// ── RESET ─────────────────────────────────────────────────────────────────────
window.doReset = function(){
  document.querySelectorAll('input:not([type=checkbox]):not([type=file]), select, textarea').forEach(function(el){
    if(el.id === 'company')      el.value = 'Natural Resources Canada';
    else if(el.id === 'primaryGroup') el.value = 'Domain Users';
    else if(el.readOnly)         return;
    else                         el.value = '';
  });
  document.querySelectorAll('input[type=checkbox]').forEach(function(cb){
    cb.checked = ['mustChangePw','allowRDP','mfaRequired'].indexOf(cb.id) !== -1;
  });
  document.querySelectorAll('.invalid').forEach(function(el){ el.classList.remove('invalid'); });
  document.querySelectorAll('.errmsg.show').forEach(function(el){ el.classList.remove('show'); });
  document.getElementById('valBox').classList.remove('show');
  document.getElementById('expiryWrap').style.display = 'none';
  document.getElementById('sbar').style.width = '0';
  document.getElementById('slbl').textContent = '';
  manualUpn = false; manualSam = false; manualDisplay = false;
  calcUAC();
  showToast('Form cleared', '#444');
};

// init
calcUAC();

})();
</script>
</body>
</html>
