<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── Navigation ──
let currentSection = 0;
const totalSections = 8;

function goTo(idx) {
  document.querySelectorAll('.form-section').forEach((s, i) => {
    s.classList.toggle('active', i === idx);
  });
  document.querySelectorAll('.nav-tab').forEach((t, i) => {
    t.classList.toggle('active', i === idx);
  });
  currentSection = idx;
  document.getElementById('actionStatus').textContent =
    `Section ${idx + 1} of ${totalSections} — ${document.querySelectorAll('.nav-tab')[idx].textContent}`;
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

// ── Auto-generate names ──
function autoGenerate() {
  const fn = val('givenName'), mn = val('initials'), ln = val('sn');
  if (fn || ln) {
    setIfEmpty('displayName', [fn, ln].filter(Boolean).join(' '));
    setIfEmpty('cn', [fn, mn ? mn + '.' : '', ln].filter(Boolean).join(' ').trim());
  }
}
function setIfEmpty(id, v) {
  const el = document.getElementById(id);
  if (!el.dataset.userEdited) el.value = v;
}
['displayName','cn'].forEach(id => {
  document.getElementById(id).addEventListener('input', function() {
    this.dataset.userEdited = '1';
  });
});

// ── Sync SAM → UPN ──
function syncUPN() {
  const sam = val('sAMAccountName');
  const upn = document.getElementById('userPrincipalName');
  if (!upn.dataset.userEdited && sam) {
    upn.value = sam + '@corp.example.com';
  }
}
document.getElementById('userPrincipalName').addEventListener('input', function() {
  this.dataset.userEdited = '1';
});

// ── Password strength ──
function checkPW() {
  const pw = val('password');
  const bars = [1,2,3,4].map(i => document.getElementById('pw'+i));
  const label = document.getElementById('pwLabel');
  bars.forEach(b => b.className = 'pw-bar');
  let score = 0;
  if (pw.length >= 8) score++;
  if (/[A-Z]/.test(pw)) score++;
  if (/[0-9]/.test(pw)) score++;
  if (/[^A-Za-z0-9]/.test(pw)) score++;
  const cls = score <= 1 ? 'weak' : score <= 2 ? 'medium' : 'strong';
  const labels = ['','Weak','Fair','Strong','Very Strong'];
  for (let i = 0; i < score; i++) bars[i].classList.add(cls);
  label.textContent = pw.length === 0 ? 'Enter a password' : (labels[score] || 'Very Strong');
}

// ── Helpers ──
function val(id) { return (document.getElementById(id)?.value || '').trim(); }
function checked(id) { return document.getElementById(id)?.checked || false; }

// ── Collect all data ──
function collectData() {
  const fields = [
    'givenName','initials','sn','displayName','cn','generationQualifier','personalTitle',
    'middleName','ou','employeeType','employeeID','employeeNumber','badgeID',
    'sAMAccountName','userPrincipalName','accountExpires','logonHours','userWorkstations',
    'pwdLastSet','resultantPSO',
    'profilePath','scriptPath','homeDrive','homeDirectory','tsProfilePath','tsHomeDirectory',
    'tsHomeDrive','tsInitialProgram',
    'title','department','company','division','manager','assistant','costCenter','businessUnit',
    'physicalDeliveryOfficeName','l',
    'mail','proxyAddresses','telephoneNumber','mobile','homePhone','pager','ipPhone',
    'facsimileTelephoneNumber','otherTelephone','otherMobile','wWWHomePage',
    'streetAddress','postOfficeBox','city','st','postalCode','co',
    'memberOf','primaryGroupID','mailNickname','homeMDB','msExchHomeServerName',
    'extensionAttribute3','extensionAttribute4','extensionAttribute5',
    'extensionAttribute6','extensionAttribute7','extensionAttribute8',
    'description','info','userAccountControl','preferredLanguage','thumbnailPhoto','userCertificate'
  ];
  const boolFields = [
    'mustChangePW','cannotChangePW','pwNeverExpires','accountDisabled',
    'smartcardRequired','trustedForDelegation','dontRequirePreauth','sensitiveNoDelegate',
    'tsAllowLogon','hideFromAddressList'
  ];
  const data = { _meta: { generatedAt: new Date().toISOString(), tool: 'AD User Provisioning Form' } };
  fields.forEach(id => { const v = val(id); if (v) data[id] = v; });
  boolFields.forEach(id => { data[id] = checked(id); });
  return data;
}

// ── Summary builder ──
function buildSummary() {
  const data = collectData();
  const grid = document.getElementById('summaryGrid');
  const sections = {
    'Identity': ['givenName','initials','sn','displayName','cn','employeeType','employeeID','ou'],
    'Account': ['sAMAccountName','userPrincipalName','accountExpires','logonHours','mustChangePW','pwNeverExpires','accountDisabled'],
    'Profile': ['profilePath','scriptPath','homeDrive','homeDirectory'],
    'Organization': ['title','department','company','manager','physicalDeliveryOfficeName'],
    'Contact': ['mail','telephoneNumber','mobile'],
    'Address': ['streetAddress','city','st','postalCode','co'],
    'Groups': ['memberOf','mailNickname','description'],
  };
  let html = '';
  for (const [sec, keys] of Object.entries(sections)) {
    const items = keys.map(k => {
      const v = data[k] === true ? '✓ Yes' : data[k] === false ? '✗ No' : (data[k] || '');
      return v ? `<div class="summary-item"><div class="summary-key">${k}</div><div class="summary-val">${escHtml(v)}</div></div>` : '';
    }).filter(Boolean).join('');
    if (items) html += `<div class="summary-section-title">${sec}</div>${items}`;
  }
  grid.innerHTML = html || '<p style="color:var(--text-dim);font-size:13px;">No data entered yet.</p>';
}

function escHtml(s) {
  return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}

// ── Print ──
function printForm() {
  showToast('Sending to printer…', 'success');
  setTimeout(() => window.print(), 300);
}

// ── Save JSON ──
function saveJSON() {
  const data = collectData();
  const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
  download(blob, `ad-user-${(data.sAMAccountName || 'new')}.json`);
  showToast('JSON saved successfully', 'success');
}

// ── Save HTML ──
function saveHTML() {
  const data = collectData();
  const rows = Object.entries(data)
    .filter(([k]) => k !== '_meta')
    .map(([k,v]) => `<tr><td class="attr">${escHtml(k)}</td><td>${escHtml(String(v))}</td></tr>`)
    .join('\n');

  const html = `<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>AD User: ${escHtml(data.displayName || data.sAMAccountName || 'New User')}</title>
<style>
  body{font-family:'Segoe UI',Arial,sans-serif;max-width:800px;margin:40px auto;color:#1e293b;background:#f8fafc;padding:24px}
  h1{font-size:22px;margin-bottom:4px;color:#0f172a}
  .meta{font-size:12px;color:#64748b;margin-bottom:28px}
  table{width:100%;border-collapse:collapse;background:white;box-shadow:0 1px 4px rgba(0,0,0,.08);border-radius:8px;overflow:hidden}
  th{background:#1e40af;color:white;text-align:left;padding:10px 16px;font-size:12px;letter-spacing:.05em;text-transform:uppercase}
  td{padding:9px 16px;font-size:13px;border-bottom:1px solid #e2e8f0}
  td.attr{font-family:monospace;font-size:12px;color:#475569;width:42%;font-weight:500}
  tr:last-child td{border-bottom:none}
