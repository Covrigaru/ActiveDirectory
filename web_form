<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Active Directory — New User Provisioning</title>
<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=IBM+Plex+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d0f14;
    --surface: #13161e;
    --surface2: #1a1e28;
    --border: #252a38;
    --border-focus: #3b82f6;
    --accent: #3b82f6;
    --accent2: #60a5fa;
    --accent-glow: rgba(59,130,246,0.15);
    --text: #e2e8f0;
    --text-dim: #64748b;
    --text-muted: #334155;
    --label: #94a3b8;
    --success: #10b981;
    --warn: #f59e0b;
    --danger: #ef4444;
    --mono: 'IBM Plex Mono', monospace;
    --sans: 'IBM Plex Sans', sans-serif;
    --radius: 6px;
    --transition: 0.18s ease;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--sans);
    font-size: 14px;
    min-height: 100vh;
    line-height: 1.6;
    background-image:
      radial-gradient(ellipse 80% 40% at 50% -10%, rgba(59,130,246,0.08) 0%, transparent 60%),
      repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.015) 39px, rgba(255,255,255,0.015) 40px),
      repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.015) 39px, rgba(255,255,255,0.015) 40px);
  }

  /* ── Header ── */
  .site-header {
    border-bottom: 1px solid var(--border);
    background: rgba(13,15,20,0.9);
    backdrop-filter: blur(12px);
    position: sticky;
    top: 0;
    z-index: 100;
    padding: 0 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 56px;
  }
  .header-brand {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .header-icon {
    width: 28px;
    height: 28px;
    background: var(--accent);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
  }
  .header-title {
    font-family: var(--mono);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--text);
  }
  .header-sub {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    letter-spacing: 0.08em;
  }
  .header-badge {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    color: var(--accent2);
    background: rgba(59,130,246,0.1);
    border: 1px solid rgba(59,130,246,0.25);
    padding: 3px 8px;
    border-radius: 3px;
    letter-spacing: 0.08em;
  }

  /* ── Layout ── */
  .page-wrapper {
    max-width: 900px;
    margin: 0 auto;
    padding: 40px 24px 120px;
  }

  .page-intro {
    margin-bottom: 40px;
  }
  .page-intro h1 {
    font-family: var(--mono);
    font-size: 22px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
  }
  .page-intro p {
    font-size: 13px;
    color: var(--text-dim);
    max-width: 560px;
  }
  .breadcrumb {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
    margin-bottom: 16px;
    letter-spacing: 0.05em;
  }
  .breadcrumb span { color: var(--text-muted); margin: 0 6px; }

  /* ── Progress nav ── */
  .section-nav {
    display: flex;
    gap: 0;
    margin-bottom: 36px;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--surface);
  }
  .nav-tab {
    flex: 1;
    padding: 10px 8px;
    text-align: center;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--text-dim);
    cursor: pointer;
    border-right: 1px solid var(--border);
    transition: all var(--transition);
    text-transform: uppercase;
    user-select: none;
  }
  .nav-tab:last-child { border-right: none; }
  .nav-tab:hover { background: var(--surface2); color: var(--label); }
  .nav-tab.active { background: var(--accent-glow); color: var(--accent2); border-bottom: 2px solid var(--accent); }

  /* ── Form Sections ── */
  .form-section {
    display: none;
    animation: fadeIn 0.2s ease;
  }
  .form-section.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  .section-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--border);
  }
  .section-num {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--accent);
    background: var(--accent-glow);
    border: 1px solid rgba(59,130,246,0.3);
    padding: 2px 7px;
    border-radius: 3px;
    letter-spacing: 0.08em;
  }
  .section-title {
    font-family: var(--mono);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.03em;
  }
  .section-desc {
    font-size: 12px;
    color: var(--text-dim);
    margin-left: auto;
  }

  /* ── Field Grid ── */
  .field-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }
  .field-grid.cols-3 { grid-template-columns: 1fr 1fr 1fr; }
  .field-grid.cols-1 { grid-template-columns: 1fr; }
  .span-2 { grid-column: span 2; }
  .span-3 { grid-column: span 3; }

  /* ── Field ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .field label {
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--label);
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .required-dot {
    width: 4px;
    height: 4px;
    background: var(--accent);
    border-radius: 50%;
    display: inline-block;
    flex-shrink: 0;
  }
  .field-hint {
    font-family: var(--sans);
    font-size: 10px;
    color: var(--text-muted);
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    margin-left: auto;
  }

  input[type="text"],
  input[type="email"],
  input[type="password"],
  input[type="tel"],
  input[type="number"],
  input[type="date"],
  input[type="url"],
  select,
  textarea {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    color: var(--text);
    font-family: var(--sans);
    font-size: 13px;
    padding: 9px 12px;
    width: 100%;
    transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
    outline: none;
    appearance: none;
  }
  input:focus, select:focus, textarea:focus {
    border-color: var(--border-focus);
    background: var(--surface2);
    box-shadow: 0 0 0 3px var(--accent-glow);
  }
  input::placeholder, textarea::placeholder { color: var(--text-muted); font-size: 12px; }
  select option { background: var(--surface2); color: var(--text); }
  textarea { resize: vertical; min-height: 72px; line-height: 1.5; }

  /* checkbox / toggle */
  .toggle-field {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
    cursor: pointer;
    transition: border-color var(--transition), background var(--transition);
  }
  .toggle-field:hover { border-color: var(--border-focus); background: var(--surface2); }
  .toggle-label { font-size: 12px; color: var(--label); }
  .toggle-switch {
    width: 36px;
    height: 20px;
    background: var(--text-muted);
    border-radius: 10px;
    position: relative;
    transition: background var(--transition);
    flex-shrink: 0;
  }
  .toggle-switch::after {
    content: '';
    position: absolute;
    top: 3px;
    left: 3px;
    width: 14px;
    height: 14px;
    background: white;
    border-radius: 50%;
    transition: left var(--transition);
  }
  input[type="checkbox"] { display: none; }
  input[type="checkbox"]:checked + .toggle-field .toggle-switch { background: var(--accent); }
  input[type="checkbox"]:checked + .toggle-field .toggle-switch::after { left: 19px; }

  /* ── Divider ── */
  .field-divider {
    grid-column: 1 / -1;
    border: none;
    border-top: 1px solid var(--border);
    margin: 4px 0;
  }
  .field-group-label {
    grid-column: 1 / -1;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    padding-top: 4px;
  }

  /* ── Navigation buttons ── */
  .nav-buttons {
    display: flex;
    justify-content: space-between;
    margin-top: 32px;
    padding-top: 20px;
    border-top: 1px solid var(--border);
  }

  .btn {
    font-family: var(--mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 10px 20px;
    border-radius: var(--radius);
    border: 1px solid transparent;
    cursor: pointer;
    transition: all var(--transition);
    display: inline-flex;
    align-items: center;
    gap: 7px;
  }
  .btn-ghost {
    background: transparent;
    border-color: var(--border);
    color: var(--text-dim);
  }
  .btn-ghost:hover { border-color: var(--label); color: var(--text); background: var(--surface2); }
  .btn-primary {
    background: var(--accent);
    border-color: var(--accent);
    color: white;
  }
  .btn-primary:hover { background: var(--accent2); border-color: var(--accent2); box-shadow: 0 0 20px var(--accent-glow); }
  .btn-success {
    background: transparent;
    border-color: var(--success);
    color: var(--success);
  }
  .btn-success:hover { background: rgba(16,185,129,0.1); box-shadow: 0 0 16px rgba(16,185,129,0.15); }
  .btn-warn {
    background: transparent;
    border-color: var(--warn);
    color: var(--warn);
  }
  .btn-warn:hover { background: rgba(245,158,11,0.1); }
  .btn-danger {
    background: transparent;
    border-color: var(--danger);
    color: var(--danger);
  }
  .btn-danger:hover { background: rgba(239,68,68,0.1); }

  /* ── Action Bar (bottom fixed) ── */
  .action-bar {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(13,15,20,0.95);
    backdrop-filter: blur(16px);
    border-top: 1px solid var(--border);
    padding: 16px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 200;
  }
  .action-bar-left {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text-dim);
  }
  .action-bar-right { display: flex; gap: 10px; }

  /* ── Toast ── */
  .toast {
    position: fixed;
    top: 72px;
    right: 24px;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 16px;
    font-family: var(--mono);
    font-size: 11px;
    color: var(--text);
    z-index: 999;
    opacity: 0;
    transform: translateY(-8px);
    transition: all 0.25s ease;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .toast.show { opacity: 1; transform: translateY(0); }
  .toast.success { border-color: var(--success); }
  .toast.error { border-color: var(--danger); }

  /* ── Password strength ── */
  .pw-strength {
    display: flex;
    gap: 4px;
    margin-top: 4px;
  }
  .pw-bar {
    flex: 1;
    height: 3px;
    background: var(--border);
    border-radius: 2px;
    transition: background 0.3s;
  }
  .pw-bar.weak { background: var(--danger); }
  .pw-bar.medium { background: var(--warn); }
  .pw-bar.strong { background: var(--success); }
  .pw-label { font-family: var(--mono); font-size: 10px; color: var(--text-dim); margin-top: 4px; }

  /* ── Summary page ── */
  .summary-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
  }
  .summary-item {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 10px 14px;
  }
  .summary-key {
    font-family: var(--mono);
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 3px;
  }
  .summary-val {
    font-size: 13px;
    color: var(--text);
    word-break: break-all;
  }
  .summary-section-title {
    grid-column: 1 / -1;
    font-family: var(--mono);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    padding: 8px 0 4px;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  @media (max-width: 640px) {
    .field-grid, .field-grid.cols-3 { grid-template-columns: 1fr; }
    .span-2, .span-3 { grid-column: span 1; }
    .summary-grid { grid-template-columns: 1fr; }
    .section-nav { flex-wrap: wrap; }
    .nav-tab { font-size: 9px; }
  }

  @media print {
    .site-header, .action-bar, .nav-buttons, .section-nav { display: none !important; }
    .form-section { display: block !important; margin-bottom: 32px; }
    body { background: white; color: black; }
    input, select, textarea { border: 1px solid #ccc; background: white; color: black; }
  }
</style>
</head>
<body>

<header class="site-header">
  <div class="header-brand">
    <div class="header-icon">🖥</div>
    <div>
      <div class="header-title">Active Directory</div>
      <div class="header-sub">User Provisioning Form</div>
    </div>
  </div>
  <div class="header-badge">AD DS · Windows Server</div>
</header>

<div class="page-wrapper">
  <div class="page-intro">
    <div class="breadcrumb">AD Users & Computers <span>›</span> New User <span>›</span> Provision</div>
    <h1>New User Object</h1>
    <p>Complete all applicable fields across the sections below. Required fields are indicated with a blue dot. Use the tab navigation to move between attribute groups.</p>
  </div>

  <div class="section-nav" id="sectionNav">
    <div class="nav-tab active" onclick="goTo(0)">01 · Identity</div>
    <div class="nav-tab" onclick="goTo(1)">02 · Account</div>
    <div class="nav-tab" onclick="goTo(2)">03 · Profile</div>
    <div class="nav-tab" onclick="goTo(3)">04 · Organization</div>
    <div class="nav-tab" onclick="goTo(4)">05 · Contact</div>
    <div class="nav-tab" onclick="goTo(5)">06 · Address</div>
    <div class="nav-tab" onclick="goTo(6)">07 · Groups & Attrs</div>
    <div class="nav-tab" onclick="goTo(7)">08 · Review</div>
  </div>

  <!-- ══════════════ SECTION 1: IDENTITY ══════════════ -->
  <div class="form-section active" id="section-0">
    <div class="section-header">
      <span class="section-num">01</span>
      <span class="section-title">Identity &amp; Name</span>
      <span class="section-desc">Core identity attributes</span>
    </div>
    <div class="field-grid">
      <div class="field">
        <label><span class="required-dot"></span> First Name <span class="field-hint">givenName</span></label>
        <input type="text" id="givenName" placeholder="John" oninput="autoGenerate()">
      </div>
      <div class="field">
        <label>Middle Name / Initials <span class="field-hint">initials</span></label>
        <input type="text" id="initials" placeholder="M" maxlength="6" oninput="autoGenerate()">
      </div>
      <div class="field">
        <label><span class="required-dot"></span> Last Name <span class="field-hint">sn</span></label>
        <input type="text" id="sn" placeholder="Doe" oninput="autoGenerate()">
      </div>
      <div class="field">
        <label>Display Name <span class="field-hint">displayName</span></label>
        <input type="text" id="displayName" placeholder="Auto-generated">
      </div>
      <div class="field">
        <label>Full Name / CN <span class="field-hint">cn</span></label>
        <input type="text" id="cn" placeholder="Auto-generated">
      </div>
      <div class="field">
        <label>Name Suffix <span class="field-hint">generationQualifier</span></label>
        <input type="text" id="generationQualifier" placeholder="Jr., Sr., III">
      </div>
      <div class="field">
        <label>Personal Title <span class="field-hint">personalTitle</span></label>
        <input type="text" id="personalTitle" placeholder="Dr., Prof., Eng.">
      </div>
      <div class="field">
        <label>Nick Name <span class="field-hint">middleName</span></label>
        <input type="text" id="middleName" placeholder="Preferred name / alias">
      </div>
      <hr class="field-divider">
      <div class="field-group-label">Organizational Unit Placement</div>
      <div class="field span-2">
        <label><span class="required-dot"></span> Target OU (Distinguished Name) <span class="field-hint">path</span></label>
        <input type="text" id="ou" placeholder="OU=Users,OU=Toronto,DC=corp,DC=example,DC=com">
      </div>
      <div class="field">
        <label>Employee Type <span class="field-hint">employeeType</span></label>
        <select id="employeeType">
          <option value="">— Select —</option>
          <option>Full-Time</option>
          <option>Part-Time</option>
          <option>Contractor</option>
          <option>Temporary</option>
          <option>Intern</option>
          <option>Consultant</option>
          <option>Vendor</option>
          <option>Service Account</option>
        </select>
      </div>
      <div class="field">
        <label>Employee ID <span class="field-hint">employeeID</span></label>
        <input type="text" id="employeeID" placeholder="EMP-00123">
      </div>
      <div class="field">
        <label>Employee Number <span class="field-hint">employeeNumber</span></label>
        <input type="text" id="employeeNumber" placeholder="00123">
      </div>
      <div class="field">
        <label>Badge / Smart Card ID <span class="field-hint">msDS-cloudExtensionAttribute1</span></label>
        <input type="text" id="badgeID" placeholder="Badge or card number">
      </div>
    </div>
    <div class="nav-buttons">
      <span></span>
      <button class="btn btn-primary" onclick="goTo(1)">Account →</button>
    </div>
  </div>

  <!-- ══════════════ SECTION 2: ACCOUNT ══════════════ -->
  <div class="form-section" id="section-1">
    <div class="section-header">
      <span class="section-num">02</span>
      <span class="section-title">Account &amp; Security</span>
      <span class="section-desc">Logon, password, and access policy</span>
    </div>
    <div class="field-grid">
      <div class="field">
        <label><span class="required-dot"></span> SAM Account Name <span class="field-hint">sAMAccountName</span></label>
        <input type="text" id="sAMAccountName" placeholder="jdoe" oninput="syncUPN()">
      </div>
      <div class="field">
        <label><span class="required-dot"></span> UPN (User Logon Name) <span class="field-hint">userPrincipalName</span></label>
        <input type="text" id="userPrincipalName" placeholder="jdoe@corp.example.com">
      </div>
      <div class="field span-2">
        <label><span class="required-dot"></span> Password <span class="field-hint">AccountPassword</span></label>
        <input type="password" id="password" placeholder="Min. 8 chars, complexity required" oninput="checkPW()">
        <div class="pw-strength">
          <div class="pw-bar" id="pw1"></div>
          <div class="pw-bar" id="pw2"></div>
          <div class="pw-bar" id="pw3"></div>
          <div class="pw-bar" id="pw4"></div>
        </div>
        <div class="pw-label" id="pwLabel">Enter a password</div>
      </div>
      <div class="field span-2">
        <label>Confirm Password</label>
        <input type="password" id="confirmPassword" placeholder="Re-enter password">
      </div>
      <hr class="field-divider">
      <div class="field-group-label">Account Flags</div>

      <label><input type="checkbox" id="mustChangePW" checked><div class="toggle-field"><span class="toggle-label">User must change password at next logon</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="cannotChangePW"><div class="toggle-field"><span class="toggle-label">User cannot change password</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="pwNeverExpires"><div class="toggle-field"><span class="toggle-label">Password never expires</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="accountDisabled"><div class="toggle-field"><span class="toggle-label">Account is disabled</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="smartcardRequired"><div class="toggle-field"><span class="toggle-label">Smartcard is required for interactive logon</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="trustedForDelegation"><div class="toggle-field"><span class="toggle-label">Account is trusted for delegation (Kerberos)</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="dontRequirePreauth"><div class="toggle-field"><span class="toggle-label">Do not require Kerberos preauthentication</span><div class="toggle-switch"></div></div></label>
      <label><input type="checkbox" id="sensitiveNoDelegate"><div class="toggle-field"><span class="toggle-label">Account is sensitive — cannot be delegated</span><div class="toggle-switch"></div></div></label>

      <hr class="field-divider">
      <div class="field-group-label">Account Lifecycle</div>
      <div class="field">
        <label>Account Expiration Date <span class="field-hint">accountExpires</span></label>
        <input type="date" id="accountExpires">
      </div>
      <div class="field">
        <label>Logon Hours Policy <span class="field-hint">logonHours</span></label>
        <select id="logonHours">
          <option value="">All hours (default)</option>
